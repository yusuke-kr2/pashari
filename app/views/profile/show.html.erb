<div class="page-content">
  <h1 class="page-title"><%= t('.title') %></h1>

  <div class="card mb-3">
    <div class="card-body">
      <div class="d-flex align-items-center mb-3">
        <div class="member-avatar" style="width: 48px; height: 48px; font-size: 1.2rem;">
          <i class="bi bi-person"></i>
        </div>
        <div style="margin-left: 12px;">
          <div style="font-weight: 500;"><%= current_user.email %></div>
        </div>
      </div>

      <div class="d-flex gap-4" style="font-size: 0.85rem; color: #999;">
        <div>
          <i class="bi bi-people"></i> <%= t('.groups_count', count: @groups.count) %>
        </div>
        <div>
          <i class="bi bi-camera"></i> <%= t('.photos_count', count: @photo_count) %>
        </div>
      </div>
    </div>
  </div>

  <h2 style="font-size: 0.9rem; font-weight: 600; color: #666; margin-bottom: 12px;">
    <i class="bi bi-people"></i> <%= t('.joined_groups') %>
  </h2>

  <% if @groups.any? %>
    <% @groups.each do |group| %>
      <%= link_to group_path(group), class: "group-card" do %>
        <div class="group-name"><%= group.name %></div>
        <div class="group-meta">
          <i class="bi bi-people"></i> <%= group.members.count %>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <div class="empty-state">
      <div class="empty-icon"><i class="bi bi-people"></i></div>
      <p class="empty-text"><%= t('.no_groups') %></p>
    </div>
  <% end %>

  <div class="mt-4">
    <%= button_to t('.logout'), destroy_user_session_path, method: :delete, class: "btn btn-outline-danger w-100" %>
  </div>
</div>

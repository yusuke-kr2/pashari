<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pashari" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pashari">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : t('ogp.description') %>">
    <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : 'Pashari' %>">
    <meta property="og:description" content="<%= content_for?(:description) ? yield(:description) : t('ogp.description') %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= asset_url('ogp.png') rescue image_url('ogp.png') rescue '' %>">
    <meta property="og:site_name" content="Pashari">
    <meta property="og:locale" content="ja_JP">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for?(:title) ? yield(:title) : 'Pashari' %>">
    <meta name="twitter:description" content="<%= content_for?(:description) ? yield(:description) : t('ogp.description') %>">
    <meta name="twitter:image" content="<%= asset_url('ogp.png') rescue image_url('ogp.png') rescue '' %>">

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <meta name="theme-color" content="#FAF7F2">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="<%= 'camera-page' if content_for?(:camera_mode) %>">
    <% unless content_for?(:camera_mode) %>
      <div class="app-header">
        <span class="app-title">Pashari</span>
      </div>
    <% end %>

    <%= render 'shared/flash' %>
    <%= yield %>

    <% if user_signed_in? && !content_for?(:camera_mode) %>
      <%= render 'shared/tab_bar' %>
    <% end %>
  </body>
</html>

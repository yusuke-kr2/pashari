<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0"><%= t('.title') %></h1>
    <%= link_to t('.new_group'), new_group_path, class: "btn btn-primary" %>
  </div>

  <% if @groups.any? %>
    <div class="list-group">
      <% @groups.each do |group| %>
        <%= link_to group.name, group_path(group), class: "list-group-item list-group-item-action" %>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted"><%= t('.empty') %></p>
  <% end %>
</div>

<div class="container mt-4">
  <h1><%= t('.title') %></h1>

  <% if @groups.any? %>
    <div class="list-group">
      <% @groups.each do |group| %>
        <%= link_to group.name, group_path(group), class: "list-group-item list-group-item-action" %>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted"><%= t('.empty') %></p>
  <% end %>
</div>

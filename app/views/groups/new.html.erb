<div class="container mt-4">
  <h1><%= t('.title') %></h1>

  <%= form_with(model: @group, class: "mt-3") do |f| %>
    <% if @group.errors.any? %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @group.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :name, t('.name'), class: "form-label" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :photo_limit, t('.photo_limit'), class: "form-label" %>
      <%= f.number_field :photo_limit, class: "form-control", value: @group.photo_limit || 27, min: 1 %>
      <div class="form-text"><%= t('.photo_limit_hint') %></div>
    </div>

    <%= f.submit t('.submit'), class: "btn btn-primary w-100" %>
  <% end %>
</div>

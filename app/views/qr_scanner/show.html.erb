<div class="page-content" data-controller="qr-scanner">
  <h1 class="page-title"><%= t('.title') %></h1>

  <div class="card mb-3" style="overflow: hidden;">
    <video data-qr-scanner-target="video" autoplay playsinline style="width: 100%; aspect-ratio: 1; object-fit: cover;"></video>
  </div>

  <canvas data-qr-scanner-target="canvas" class="d-none"></canvas>

  <p class="text-center" style="font-size: 0.85rem; color: #999;">
    <span data-qr-scanner-target="status"><%= t('.instruction') %></span>
  </p>

  <div class="mt-3">
    <%= link_to t('.back'), groups_path, class: "btn btn-pashari-outline w-100" %>
  </div>
</div>

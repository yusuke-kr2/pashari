<div class="container mt-4" data-controller="camera" data-camera-url-value="<%= group_photos_path(@group) %>" data-camera-token-value="<%= form_authenticity_token %>">
  <div class="text-center">
    <p class="mb-2">
      <strong><%= t('.remaining') %>:</strong>
      <%= @remaining == Float::INFINITY ? t('.unlimited') : @remaining %>
    </p>

    <div class="position-relative d-inline-block">
      <video data-camera-target="video" autoplay playsinline class="w-100 rounded" style="max-height: 70vh;"></video>
    </div>

    <canvas data-camera-target="canvas" class="d-none"></canvas>

    <div class="mt-3">
      <button data-action="click->camera#capture" class="btn btn-danger btn-lg rounded-circle" style="width: 72px; height: 72px;" data-camera-target="shutter">
        📷
      </button>
    </div>

    <div class="mt-2">
      <%= link_to t('.back'), group_path(@group), class: "btn btn-outline-secondary btn-sm" %>
    </div>
  </div>
</div>

<% content_for :camera_mode, true %>

<div data-controller="camera" data-camera-url-value="<%= group_photos_path(@group) %>" data-camera-token-value="<%= form_authenticity_token %>" style="height: 100dvh; display: flex; flex-direction: column;">
  <div class="text-center remaining-count">
    <%= t('.remaining') %>:
    <%= @remaining == Float::INFINITY ? t('.unlimited') : @remaining %>
  </div>

  <div style="flex: 1; display: flex; align-items: center; justify-content: center; overflow: hidden;">
    <video data-camera-target="video" autoplay playsinline style="width: 100%; height: 100%; object-fit: cover;"></video>
  </div>

  <canvas data-camera-target="canvas" class="d-none"></canvas>

  <div style="padding: 20px 0 32px; display: flex; justify-content: center; align-items: center; gap: 40px;">
    <%= link_to group_path(@group), style: "color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.8rem;" do %>
      <i class="bi bi-arrow-left" style="font-size: 1.2rem;"></i>
    <% end %>

    <button data-action="click->camera#capture" class="shutter-btn" data-camera-target="shutter"></button>

    <div style="width: 24px;"></div>
  </div>
</div>

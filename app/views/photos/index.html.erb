<div class="page-content">
  <h1 class="page-title"><%= @group.name %></h1>

  <% if @developing_photos.any? %>
    <h2 style="font-size: 0.85rem; font-weight: 600; color: #999; margin-bottom: 10px;">
      <i class="bi bi-hourglass-split"></i> <%= t('.developing') %>
    </h2>
    <div class="photo-grid mb-4">
      <% @developing_photos.each do |photo| %>
        <div class="developing-card" data-controller="countdown" data-countdown-deadline-value="<%= photo.visible_at.iso8601 %>">
          <div>
            <div class="developing-icon"><i class="bi bi-film"></i></div>
            <div class="developing-time">
              <span data-countdown-target="display"><%= t('.remaining_time', time: distance_of_time_in_words(Time.current, photo.visible_at)) %></span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @developed_photos.any? %>
    <h2 style="font-size: 0.85rem; font-weight: 600; color: #999; margin-bottom: 10px;">
      <i class="bi bi-check-circle"></i> <%= t('.developed') %>
    </h2>
    <div class="photo-grid">
      <% @developed_photos.each do |photo| %>
        <div class="photo-card">
          <%= image_tag photo.image if photo.image.attached? %>
          <div class="photo-info d-flex justify-content-between align-items-center">
            <div>
              <%= photo.user.email %><br>
              <%= l(photo.taken_at, format: :short) if photo.taken_at %>
            </div>
            <%= link_to download_group_photo_path(@group, photo), style: "color: #999;" do %>
              <i class="bi bi-download"></i>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @developed_photos.empty? && @developing_photos.empty? %>
    <div class="empty-state">
      <div class="empty-icon"><i class="bi bi-camera"></i></div>
      <p class="empty-text"><%= t('.empty') %></p>
    </div>
  <% end %>

  <div class="mt-4">
    <%= link_to t('.back'), group_path(@group), class: "btn btn-pashari-outline w-100" %>
  </div>
</div>

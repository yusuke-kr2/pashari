<div class="container mt-4">
  <h1><%= @group.name %> - <%= t('.title') %></h1>

  <% if @developing_photos.any? %>
    <h2 class="h5 mt-4"><%= t('.developing') %></h2>
    <div class="row g-3">
      <% @developing_photos.each do |photo| %>
        <div class="col-6 col-md-4">
          <div class="card text-center">
            <div class="card-body bg-dark text-light rounded" style="min-height: 150px; display: flex; align-items: center; justify-content: center;">
              <div>
                <p class="mb-1">🎞️</p>
                <p class="mb-0 small" data-controller="countdown" data-countdown-deadline-value="<%= photo.visible_at.iso8601 %>">
                  <span data-countdown-target="display"><%= t('.remaining_time', time: distance_of_time_in_words(Time.current, photo.visible_at)) %></span>
                </p>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @developed_photos.any? %>
    <h2 class="h5 mt-4"><%= t('.developed') %></h2>
    <div class="row g-3">
      <% @developed_photos.each do |photo| %>
        <div class="col-6 col-md-4">
          <div class="card">
            <%= image_tag photo.image, class: "card-img-top" if photo.image.attached? %>
            <div class="card-body p-2">
              <p class="card-text small text-muted mb-0">
                <%= photo.user.email %><br>
                <%= l(photo.taken_at, format: :short) if photo.taken_at %>
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @developed_photos.empty? && @developing_photos.empty? %>
    <p class="text-muted mt-3"><%= t('.empty') %></p>
  <% end %>

  <div class="mt-3">
    <%= link_to t('.back'), group_path(@group), class: "btn btn-outline-secondary" %>
  </div>
</div>
